{
  "name": "wandervoice",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @wandervoice/db db:push",
    "db:studio": "turbo -F @wandervoice/db db:studio",
    "db:generate": "turbo -F @wandervoice/db db:generate",
    "db:migrate": "turbo -F @wandervoice/db db:migrate",
    "tunnel": "bun tunnel.ts"
  },
  "packageManager": "bun@1.3.5",
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@wandervoice/env": "workspace:*"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@types/bun": "catalog:",
    "@wandervoice/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  }
}
