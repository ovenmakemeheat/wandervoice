{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@wandervoice/env": "workspace:*",
    "@wandervoice/db": "workspace:*",
    "hono": "^4.8.2"
  },
  "trustedDependencies": [
    "supabase"
  ],
  "devDependencies": {
    "typescript": "catalog:",
    "tsdown": "^0.21.9",
    "@wandervoice/config": "workspace:*",
    "@types/bun": "catalog:"
  }
}